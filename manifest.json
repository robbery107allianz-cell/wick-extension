{
  "manifest_version": 3,
  "name": "Wick",
  "version": "0.1.0",
  "description": "One-click point-in-time page snapshot, committed to your own GitHub ledger and timestamped on Bitcoin via OpenTimestamps.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.github.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
